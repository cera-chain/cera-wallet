# CERA node JSON-RPC (HTTP)
RPC_URL=http://127.0.0.1:8545
# JSON-RPC Request timeout (milliseconds) to prevent the node from hanging indefinitely when it is unresponsive.
# RPC_TIMEOUT_MS=30000

# Wallet HTTP API
PORT=3000

# Optional: PostgreSQL account metadata database (omit to run read-only/no account storage)
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/cera_wallet

# Dev only: allow posting private key in JSON body (NEVER enable in production)
# ALLOW_INSECURE_DEV_KEY_BODY=true

# Ed25519 seed for signing (32 bytes = 64 hex chars). Generate: openssl rand -hex 32
# CERA_ED25519_SEED_HEX=
